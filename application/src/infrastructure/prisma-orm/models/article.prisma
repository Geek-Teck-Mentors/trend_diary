model Article {
  articleId   BigInt   @id @default(autoincrement()) @map("article_id")
  /// メディア種別: "qiita", "zenn", "note"など
  media       String   @map("media")
  /// 記事タイトル（100文字制限）
  title       String   @map("title")
  /// 投稿者名（30文字制限）
  author      String   @map("author")
  /// 記事概要
  description String   @map("description")
  url         String   @map("url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([url])
  @@map("articles")
}
