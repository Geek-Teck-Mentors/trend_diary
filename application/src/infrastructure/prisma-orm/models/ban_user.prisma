model BannedUser {
  userId    Int      @unique @map("user_id")
  bannedAt  DateTime @default(now()) @map("banned_at")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("banned_users")
}
