model ReadHistory {
  readHistoryId BigInt   @id @default(autoincrement()) @map("read_history_id")
  readAt        DateTime @map("read_at")
  createdAt     DateTime @default(now()) @map("created_at")

  /// 記事IDは外部制約なし（記事削除後も履歴を保持するため）
  articleId    BigInt @map("article_id")
  activeUserId BigInt @map("active_user_id")

  activeUser ActiveUser @relation(fields: [activeUserId], references: [activeUserId], onDelete: Cascade)

  @@index([articleId, activeUserId], map: "idx_read_histories_article_user")
  @@map("read_histories")
}
