model SkippedArticle {
  skippedArticleId Int      @id @default(autoincrement()) @map("skipped_article_id")
  createdAt        DateTime @default(now()) @map("created_at")

  /// 記事IDは外部制約なし（記事削除後もskip履歴を保持するため）
  articleId    Int @map("article_id")
  activeUserId Int @map("active_user_id")

  activeUser ActiveUser @relation(fields: [activeUserId], references: [activeUserId], onDelete: Cascade)

  @@unique([articleId, activeUserId], name: "articleIdActiveUserId", map: "uq_skipped_articles_article_user")
  @@index([articleId, activeUserId], map: "idx_skipped_articles_article_user")
  @@map("skipped_articles")
}
